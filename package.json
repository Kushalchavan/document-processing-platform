{
  "name": "ai-document-processing-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "pnpm exec tsx watch src/server.ts",
    "build": "tsup src/server.ts src/infrastructure/workers/document.worker.ts --format esm --out-dir dist",
    "start": "node dist/server.js",
    "lint": "pnpm exec eslint .",
    "format": "pnpm exec prettier --write .",
    "migrate": "pnpm exec tsx src/infrastructure/database/migrate.ts",
    "worker": "node dist/infrastructure/workers/document.worker.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@google/genai": "^2.11.0",
    "bcrypt": "^6.0.0",
    "bullmq": "5.79.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-async-errors": "^3.1.1",
    "helmet": "^8.2.0",
    "ioredis": "5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "pdfjs-dist": "^6.1.200",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.1",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.4",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.9.0",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.10"
  }
}
